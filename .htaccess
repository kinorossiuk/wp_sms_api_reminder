Options -Indexes -MultiViews
ServerSignature Off
DirectoryIndex index.php
LimitRequestBody 32768

<LimitExcept GET POST HEAD>
  Require all denied
</LimitExcept>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://rossiuk.xyz%{REQUEST_URI} [R=301,L]
  RewriteCond %{REQUEST_URI} "(?i)(?:^|/)(?:\.env(?:[./]|$)|\.git(?:/|$)|\.svn(?:/|$)|\.hg(?:/|$)|\.aws(?:/|$)|\.ssh(?:/|$)|config(?:\.(?:php|json|ini|ya?ml|bak|old)|/|$)|wp-admin(?:/|$)|wp-login\.php|xmlrpc\.php|vendor/phpunit(?:/|$)|phpmyadmin(?:/|$)|adminer(?:\.php)?|server-status|actuator(?:/|$)|backup(?:/|$)|database\.sql)"
  RewriteRule ^ guard.php [L]
  RewriteRule ^tools/([a-z0-9-]+)/?$ index.php?tool=$1 [QSA,L]
</IfModule>

<FilesMatch "(?i)(^\.|README|composer\.(json|lock)|security\.php|\.(?:env|ini|log|sql|bak|backup|old|orig|save|swp|dist|ya?ml|toml))$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "no-referrer"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set X-Robots-Tag "noindex, nofollow, noarchive"
</IfModule>
